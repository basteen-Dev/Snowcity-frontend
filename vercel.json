{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://app.snowcityblr.com/api/:path*"
        },
        {
            "source": "/api/payphi-return",
            "destination": "/api/payphi-return"
        },
        {
            "source": "/parkpanel",
            "destination": "/parkpanel/index.html"
        },
        {
            "source": "/parkpanel/:path*",
            "destination": "/parkpanel/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}